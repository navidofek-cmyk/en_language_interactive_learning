{
  "tenses": [
    {"name": "Present Simple", "form": "V / V+s", "use": "habits, facts, routines", "example": "She works every day.", "czech": "Chodí do práce každý den."},
    {"name": "Present Continuous", "form": "am/is/are + V-ing", "use": "now, temporary, future plan", "example": "I am working right now.", "czech": "Právě pracuji."},
    {"name": "Past Simple", "form": "V-ed / irregular", "use": "completed past action", "example": "She worked yesterday.", "czech": "Včera pracovala."},
    {"name": "Past Continuous", "form": "was/were + V-ing", "use": "background action, interrupted", "example": "It was raining when I left.", "czech": "Když jsem odcházel, pršelo."},
    {"name": "Present Perfect", "form": "have/has + pp", "use": "past with present relevance", "example": "I have finished.", "czech": "Skončil/a jsem."},
    {"name": "Present Perfect Continuous", "form": "have/has been + V-ing", "use": "duration up to now", "example": "I have been working for 3 hours.", "czech": "Pracuji již 3 hodiny."},
    {"name": "Past Perfect", "form": "had + pp", "use": "before another past event", "example": "She had left before I arrived.", "czech": "Odešla dříve, než jsem přišel."},
    {"name": "Future (will)", "form": "will + V", "use": "prediction, decision, promise", "example": "I will call you.", "czech": "Zavolám ti."},
    {"name": "Future (going to)", "form": "am/is/are going to + V", "use": "plan, evidence-based prediction", "example": "I am going to study medicine.", "czech": "Chystám se studovat medicínu."},
    {"name": "Future Continuous", "form": "will be + V-ing", "use": "in progress at future time", "example": "This time tomorrow I will be flying.", "czech": "V tuto dobu zítra budu letět."},
    {"name": "Future Perfect", "form": "will have + pp", "use": "completed before future point", "example": "I will have finished by 5.", "czech": "Do 5 hodin skončím."},
    {"name": "Conditional 1", "form": "If + present, will + V", "use": "real future condition", "example": "If it rains, I will stay.", "czech": "Pokud bude pršet, zůstanu."},
    {"name": "Conditional 2", "form": "If + past, would + V", "use": "unreal present/future", "example": "If I had time, I would help.", "czech": "Kdybych měl/a čas, pomohl/a bych."},
    {"name": "Conditional 3", "form": "If + past perfect, would have + pp", "use": "unreal past", "example": "If she had studied, she would have passed.", "czech": "Kdyby studovala, udělala by zkoušku."}
  ],
