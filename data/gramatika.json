  "modals": [
    {"modal": "can", "use": "ability / permission", "example": "I can swim."},
    {"modal": "can't", "use": "inability / prohibition", "example": "You can't park here."},
    {"modal": "could", "use": "past ability / polite request", "example": "Could you help me?"},
    {"modal": "must", "use": "strong obligation (personal)", "example": "I must finish this."},
    {"modal": "mustn't", "use": "prohibition", "example": "You mustn't smoke here."},
    {"modal": "have to", "use": "external obligation", "example": "I have to wear a uniform."},
    {"modal": "don't have to", "use": "no obligation", "example": "You don't have to come."},
    {"modal": "should", "use": "advice / recommendation", "example": "You should see a doctor."},
    {"modal": "shouldn't", "use": "negative advice", "example": "You shouldn't eat so much sugar."},
    {"modal": "may", "use": "formal permission / possibility", "example": "May I leave early?"},
    {"modal": "might", "use": "weak possibility", "example": "It might rain."},
    {"modal": "would", "use": "conditional / polite", "example": "I would like a coffee."},
    {"modal": "shall", "use": "offer / suggestion (British)", "example": "Shall I open the window?"},
    {"modal": "ought to", "use": "moral obligation", "example": "You ought to apologise."},
    {"modal": "need to", "use": "necessity", "example": "I need to study."}
  ]
